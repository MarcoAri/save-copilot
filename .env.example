# GitHub Copilot CLI - Percorso del binario
COPILOT_CMD=copilot

# Opzioni aggiuntive per copilot (es. --allow-all)
COPILOT_EXTRA_ARGS=--allow-all

# DocMind - Progetto e documento da caricare come contesto
DOCMIND_PROJECT=save
DOCMIND_DOCUMENT=save-iso-prod-db-schema

# Prompt di sistema aggiuntivo (opzionale)
SYSTEM_PROMPT_EXTRA=
